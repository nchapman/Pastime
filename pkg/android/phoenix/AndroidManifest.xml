<!-- <!DOCTYPE manifest [ <!ENTITY % versionDTD SYSTEM "../../../version.dtd"> %versionDTD; ]> !-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools"
    package="com.retroarch"
    android:versionCode="1597175267"
    android:versionName="1.22.2"
    android:installLocation="internalOnly">
    <uses-feature android:glEsVersion="0x00020000" />
    <uses-feature android:name="android.hardware.type.pc" android:required="false"/>
    <uses-feature android:name="android.hardware.touchscreen" android:required="false"/>
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.gamepad" android:required="false"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- PASTIME: needed for `killFirst` external-emulator launches —
         a normal-permission no-op kill of stale background instances
         that won't pick up new ROM extras otherwise (AetherSX2 family). -->
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <!-- PASTIME: All Files Access.  Filesystem-as-configuration is the
         whole UX model — folders under Pastime/Roms/<system>/ ARE the
         library, libretro cores want raw POSIX paths, and removable SD
         cards are a first-class portable-library mechanism.  SAF would
         require a translation layer at every disk-touching site.  We
         ship via APK (no Play Store policy review) so the special-
         permission posture is fine.  Hard-gated in MainMenuActivity. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <application
        android:name="com.retroarch.playcore.RetroArchApplication"
        android:allowAudioPlaybackCapture="true"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:hasCode="true"
        android:appCategory="game"
        android:banner="@drawable/banner"
        android:extractNativeLibs="true"
        android:requestLegacyExternalStorage="true"
        tools:ignore="UnusedAttribute">
        <!-- PASTIME: drop launchMode (was singleInstance) so MainMenuActivity can share a task with RetroActivityFuture. A LAUNCHER tap mid-game then attaches a fresh MainMenuActivity to the existing task; it hits the isRunning branch, REORDER_TO_FRONTs the live game, and finish()es — game survives. -->
        <activity android:name="com.retroarch.browser.mainmenu.MainMenuActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
                <category android:name="tv.ouya.intent.category.GAME" />
            </intent-filter>
        </activity>
        <!-- PASTIME: launchMode singleTask (was singleInstance) so RetroActivityFuture joins MainMenuActivity's task — avoids two entries in the Android app switcher. -->
        <activity android:name="com.retroarch.browser.retroactivity.RetroActivityFuture" android:exported="true" android:configChanges="mcc|mnc|locale|touchscreen|keyboard|keyboardHidden|navigation|orientation|screenLayout|uiMode|screenSize|smallestScreenSize|fontScale" android:theme="@android:style/Theme.NoTitleBar.Fullscreen" android:launchMode="singleTask">
            <meta-data android:name="android.app.lib_name" android:value="retroarch-activity" />
            <meta-data android:name="android.app.func_name" android:value="ANativeActivity_onCreate" />
        </activity>
        <activity android:name="com.retroarch.browser.debug.CoreSideloadActivity" android:exported="true"/>
        <receiver android:name="com.retroarch.browser.receiver.InstalledCoresReceiver" android:exported="true">
            <intent-filter>
                <action android:name="com.retroarch.QUERY_INSTALLED_CORES" />
            </intent-filter>
        </receiver>
      <!-- PASTIME: ContentProvider that publishes Pastime/Roms files as
           content:// URIs for external emulators we launch via Intent.
           Not exported; access is granted per-Intent via
           FLAG_GRANT_READ_URI_PERMISSION in pastimeLaunchExternal(). -->
      <provider
        android:name="com.retroarch.browser.pastime.PastimeRomProvider"
        android:authorities="${applicationId}.romprovider"
        android:exported="false"
        android:grantUriPermissions="true" />
      <provider
        android:name="com.retroarch.browser.provider.RetroDocumentsProvider"
        android:authorities="${applicationId}.documents"
        android:grantUriPermissions="true"
        android:enabled="@bool/document_provider_enabled"
        android:exported="true"
        android:permission="android.permission.MANAGE_DOCUMENTS">
        <intent-filter>
          <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
        </intent-filter>
      </provider>
    </application>
</manifest>
